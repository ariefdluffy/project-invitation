# ========================================
# Wedding Invitation - Production Environment
# ========================================
# 
# ⚠️ SECURITY: Replace all values with actual production data
# ⚠️ NEVER commit this file to Git (keep in .gitignore)
# ⚠️ Store securely using password manager

# App Configuration
NODE_ENV=production
PORT=3003
HOST=0.0.0.0

# Database (PRODUCTION - separate from development)
# DB_HOST dapat berupa localhost, IP, atau domain
# DB_NAME HARUS berbeda dari dev database (wedding_db vs wedding_db_prod)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=wedding_db_prod
DB_USER=wedding_user
DB_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT_32_CHAR_MINIMUM

# Midtrans Payment Gateway
# ⚠️ CRITICAL: Gunakan PRODUCTION keys, BUKAN sandbox!
# Sandbox keys akan diklaim oleh tester, production keys untuk real transactions
MIDTRANS_CLIENT_KEY=Mid-client-XXXXXXXXXXXXXXXXXXXX
MIDTRANS_SERVER_KEY=Mid-server-XXXXXXXXXXXXXXXXXXXX
MIDTRANS_MODE=production

# Security Keys
# Generate dengan: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=RANDOM_64_CHAR_HEX_STRING_HERE_GENERATED_FROM_CRYPTO
API_KEY=RANDOM_32_CHAR_HEX_STRING_HERE

# Logging
LOG_LEVEL=error
LOG_DIR=/var/log/wedding-invitation

# Optional: Email notifications for errors
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-specific-password

# Optional: Sentry error tracking
# SENTRY_DSN=https://key@sentry.io/project-id

# Optional: Analytics
# GA_TRACKING_ID=G-XXXXXXXXXXXXX
