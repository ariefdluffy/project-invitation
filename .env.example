# ============================================================
# DATABASE (MySQL)
# ============================================================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=wedding_db

# ============================================================
# SESSION SECRET (REQUIRED for signed sessions)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ============================================================
SESSION_SECRET=change_me_to_a_random_64_char_hex_string

# ============================================================
# CLOUDFLARE TURNSTILE (required for login/register forms)
# Get from: https://dash.cloudflare.com/turnstile
# ============================================================
SECRET_KEY=your_turnstile_secret_key

# ============================================================
# SMTP EMAIL (Mailtrap recommended for development)
# Get from: https://mailtrap.io -> SMTP Settings
# ============================================================
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_password
SMTP_FROM_NAME=Wedding Invitation
SMTP_FROM_EMAIL=noreply@wedding.id

# ============================================================
# MIDTRANS PAYMENT
# Get from: https://dashboard.midtrans.com
# ============================================================
MIDTRANS_SERVER_KEY=your_midtrans_server_key
MIDTRANS_CLIENT_KEY=your_midtrans_client_key
MIDTRANS_IS_PRODUCTION=0

# ============================================================
# APP SETTINGS
# ============================================================
ORIGIN=http://localhost:3003
APP_NAME=Lembar Moment

# ============================================================
# FILE UPLOAD LIMITS
# ============================================================
MAX_FILE_SIZE=1048576
# Cloudflare Turnstile
# PUBLIC_TURNSTILE_SITE_KEY= 0x4AAAAAADIp8xx5AfGgcwB6
# TURNSTILE_SECRET_KEY= 0x4AAAAAADIp84ur3WeRXL42OuI_OJRUzGg
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
DISABLE_TURNSTILE=false
