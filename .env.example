# ============================================================
# APP ENVIRONMENT
# ============================================================
NODE_ENV=production
HOST=0.0.0.0
PORT=3003
ORIGIN=https://yourdomain.com

# ============================================================
# DATABASE (MySQL)
# ============================================================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_strong_db_password
DB_NAME=wedding_db

# ============================================================
# SESSION SECRET (REQUIRED)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ============================================================
SESSION_SECRET=change_me_to_a_random_64_char_hex_string

# ============================================================
# UPLOAD SIGNING SECRET (REQUIRED)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================
UPLOADS_SIGNING_SECRET=change_me_to_a_random_32_char_hex_string

# ============================================================
# CLOUDFLARE TURNSTILE (REQUIRED)
# Get from: https://dash.cloudflare.com/turnstile
# Test keys (development only):
#   SITE_KEY=1x00000000000000000000AA
#   SECRET_KEY=1x0000000000000000000000000000000AA
# ============================================================
SITE_KEY=your_turnstile_site_key
SECRET_KEY=your_turnstile_secret_key

# ============================================================
# ADMIN ACCOUNT (hanya dipakai saat pertama kali seed)
# Jika admin sudah ada di DB, nilai ini diabaikan
# WAJIB diisi sebelum deploy pertama kali!
# ============================================================
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change_me_to_strong_password

# ============================================================
# SMTP EMAIL (opsional - untuk fitur reset password & welcome email)
# Rekomendasi: Mailtrap (dev), Mailgun/SES (production)
# ============================================================
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password
# SMTP_FROM_NAME=Wedding Invitation
# SMTP_FROM_EMAIL=noreply@yourdomain.com

# ============================================================
# FILE UPLOAD LIMITS
# ============================================================
MAX_FILE_SIZE=1048576
